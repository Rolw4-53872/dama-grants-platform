{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft": "Information",
      "Microsoft.AspNetCore": "Information"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=.;Database=DamaGrantDb_Dev;Trusted_Connection=true;Encrypt=false;"
  },
  "JwtSettings": {
    "SecretKey": "dev-super-secret-key-change-this-in-production-min-32-characters",
    "Issuer": "DamaGrantDev",
    "Audience": "DamaGrantUsersDev",
    "ExpirationMinutes": 120,
    "RefreshTokenExpirationDays": 30
  },
  "Cors": {
    "AllowedOrigins": "http://localhost:3000,http://localhost:3001,http://localhost:8000"
  },
  "EmailSettings": {
    "SmtpServer": "localhost",
    "SmtpPort": 1025,
    "SenderEmail": "dev@dama.local",
    "SenderPassword": "dev",
    "EnableSSL": false
  },
  "AzureBlobStorage": {
    "ConnectionString": "UseDevelopmentStorage=true",
    "ContainerName": "dama-grants-dev"
  },
  "FileUpload": {
    "MaxFileSize": 104857600,
    "AllowedExtensions": ".pdf,.doc,.docx,.xls,.xlsx,.jpg,.jpeg,.png,.txt",
    "StoragePath": "./uploads"
  }
}
